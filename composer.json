{
    "name": "harvirsidhu/filament-timepicker",
    "description": "A smart, type-ahead time picker field for Filament. Type freely (3p, 330, 3:30 PM) with a filterable, keyboard-navigable suggestion dropdown.",
    "keywords": [
        "harvirsidhu",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-timepicker",
        "time-picker",
        "timepicker",
        "form-field",
        "time"
    ],
    "homepage": "https://github.com/harvirsidhu/filament-timepicker",
    "support": {
        "issues": "https://github.com/harvirsidhu/filament-timepicker/issues",
        "source": "https://github.com/harvirsidhu/filament-timepicker"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "harvirsidhu",
            "email": "harvirsidhu@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Harvirsidhu\\FilamentTimepicker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Harvirsidhu\\FilamentTimepicker\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Harvirsidhu\\FilamentTimepicker\\FilamentTimepickerServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
